# ============================================================
#  SABI INTELLIGENCE SUITE — Backend Environment Variables
#  A product of Cerebre Media Africa
#
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ── Node ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── CORS (comma-separated list of allowed frontend origins) ──
ALLOWED_ORIGINS=http://localhost:3000,https://sabi.cerebre.media

# ── Supabase ─────────────────────────────────────────────────
# Get these from: supabase.com → project → settings → API
SUPABASE_URL=https://abvwtlxqblimgkpejphz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── JWT Secrets ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_CLIENT_SECRET=
JWT_SA_SECRET=
JWT_EXPIRES_IN=7d

# ── Anthropic (ARIA Engine) ───────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
ARIA_MODEL=claude-sonnet-4-6
ARIA_MAX_TOKENS=2048

# ── Upstash Redis (optional — for rate limiting / caching) ────
UPSTASH_REDIS_REST_URL=https://helped-meerkat-97362.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare R2 (optional — for file uploads) ───────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cerebre-plus-assets
R2_PUBLIC_URL=https://pub-63f0678ed7ec4dc29d13b9d2cffad3ae.r2.dev

# ── Resend (optional — for email delivery) ────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@cerebre.media
EMAIL_REPLY_TO=hello@cerebre.media,support@cerebre.plus
