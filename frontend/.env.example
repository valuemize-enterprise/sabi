# ============================================================
#  SABI INTELLIGENCE SUITE — Frontend Environment Variables
#  A product of Cerebre Media Africa
#
#  Copy this file to .env.local for local dev.
#  For Vercel deployment, set these in the Vercel dashboard.
# ============================================================

# ── API Backend URL ───────────────────────────────────────────
# Local: http://localhost:4000
# Production: https://sabi-api.onrender.com (your Render URL)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Brand / Platform ─────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Sabi Intelligence Suite
NEXT_PUBLIC_COMPANY_NAME=Cerebre Media Africa
NEXT_PUBLIC_SUPPORT_EMAIL=hello@cerebre.media
